API_TOKEN=change-this-token
PIPER_BIN=/opt/piper/piper
MODELS_DIR=/app/models
DEFAULT_VOICE=pt_BR-faber-medium
DEFAULT_FORMAT=mp3
# Sintese Piper (textos longos no Render Free podem passar de 2–5 min).
PIPER_TIMEOUT_SECONDS=600
# Conversao WAV -> MP3.
FFMPEG_TIMEOUT_SECONDS=300
# Opcional: um valor so para os dois (so usado se PIPER_* / FFMPEG_* nao estiverem setados).
# REQUEST_TIMEOUT_SECONDS=600
MP3_BITRATE=96k
